# LLM API Key（必填）
# - OpenAI: https://platform.openai.com/api-keys
# - 火山方舟(ARK): https://www.volcengine.com/docs/82379/1399008
#
# 兼容两套命名：
# - 优先读取 OPENAI_API_KEY / OPENAI_BASE_URL
# - 如果未设置，则读取 ARK_API_KEY / ARK_BASE_URL
OPENAI_API_KEY=
ARK_API_KEY=

# LLM Base URL（可选）
# - OpenAI 默认可不填
# - 火山方舟示例：https://ark.cn-beijing.volces.com/api/v3
OPENAI_BASE_URL=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 使用的模型名称（可选，默认 gpt-4o）
# - 火山方舟示例：doubao-seed-2-0-pro-260215
MODEL_NAME=doubao-seed-2-0-pro-260215

# Agent 最大推理轮数（可选，默认 10）
MAX_ITERATIONS=10
